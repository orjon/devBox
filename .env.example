# Neon PostgreSQL
# pooled connection (used at runtime by the app)
DATABASE_URL="postgresql://[user]:[password]@[endpoint]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require"
# direct connection (used by prisma migrate)
DIRECT_URL="postgresql://[user]:[password]@[endpoint].[region].aws.neon.tech/[dbname]?sslmode=require"

# Auth.js
# Application base URL - used to construct OAuth callback URLs 
AUTH_URL="[https://app.domain.com]"
# random secret for authentication - generated with: npx auth secret (not linked to any other service)
AUTH_SECRET="[YOUR_SECRET]"

# GitHub OAuth app: [APP NAME]
# Client ID
AUTH_GITHUB_ID="[YOUR_GITHUB_ID]"
# Client Secret
AUTH_GITHUB_SECRET="[YOUR_GITHUB_SECRET]"

# Resend email service
RESEND_API_KEY="[YOUR_RESEND_API_KEY]"

# Set to "true" to bypass email verification (useful for local/staging when Resend free tier is limited)
# DISABLE_EMAIL_VERIFICATION="true"